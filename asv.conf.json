{
  "version": 1,
  "project": "pdfminer.six",
  "project_url": "https://github.com/core-experiments/core-pdfminer.six",
  "repo": ".",
  "branches": ["main"],
  "environment_type": "virtualenv",
  "pythons": ["3.10", "3.14"],
  "build_command": [
    "python -m pip install build",
    "python -m build --wheel --outdir {build_cache_dir} {build_dir}"
  ],
  "benchmark_dir": "benchmarks",
  "env_dir": ".asv/env",
  "results_dir": ".asv/results",
  "html_dir": ".asv/html",
  "build_cache_size": 2,
  "regressions_first_commits": {
    ".*": "upstream-baseline"
  },
  "show_commit_url": "https://github.com/core-experiments/core-pdfminer.six/commit/"
}
